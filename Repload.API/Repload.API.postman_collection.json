    {
      "name": "4-SETS-Add-and-Get",
      "item": [
        {
          "name": "1. Add Set to Workout (Bench Press)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('token');",
                  "const workoutId = pm.environment.get('workoutId');",
                  "const exerciseId1 = pm.environment.get('exerciseId1');",
                  "",
                  "const missing = [];",
                  "if (!token) missing.push('token');",
                  "if (!workoutId) missing.push('workoutId');",
                  "if (!exerciseId1) missing.push('exerciseId1');",
                  "",
                  "if (missing.length > 0) {",
                  "    throw new Error('Missing: ' + missing.join(', '));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('setId1', jsonData.id);",
                  "    pm.test('Set 1 added', function() {",
                  "        pm.expect(jsonData.reps).to.equal(10);",
                  "        pm.expect(jsonData.weight).to.equal(185);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"exerciseId\":{{exerciseId1}},\"reps\":10,\"weight\":185,\"setNumber\":1}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/workouts/{{workoutId}}/sets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workouts", "{{workoutId}}", "sets"]
            }
          }
        },
