    {
      "name": "3-WORKOUTS-Create",
      "item": [
        {
          "name": "1. Create Workout",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('token');",
                  "if (!token) {",
                  "    throw new Error('Missing JWT token. Run Auth → Login first!');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('workoutId', jsonData.id);",
                  "    pm.environment.set('workoutName', jsonData.name);",
                  "    pm.test('Workout created successfully', function() {",
                  "        pm.expect(jsonData.name).to.equal('Monday Push Day');",
                  "        pm.expect(jsonData.userId).to.be.a('number');",
                  "    });",
                  "} else {",
                  "    pm.test('Failed to create workout', function() { pm.expect(pm.response.code).to.equal(200); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monday Push Day\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/workouts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "workouts"
              ]
