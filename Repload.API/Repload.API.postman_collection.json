                  "    pm.expect(Array.isArray(jsonData)).to.be.true;",
                  "    pm.expect(jsonData.length).to.equal(3);",
                  "    // Verify set structure",
                  "    jsonData.forEach(function(set) {",
                  "        pm.expect(set).to.have.property('id');",
                  "        pm.expect(set).to.have.property('exerciseId');",
                  "        pm.expect(set).to.have.property('exerciseName');",
                  "        pm.expect(set).to.have.property('reps');",
                  "        pm.expect(set).to.have.property('weight');",
                  "        pm.expect(set).to.have.property('setNumber');",
                  "    });",
                  "});"
                ]
