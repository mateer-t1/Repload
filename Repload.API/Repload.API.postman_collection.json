              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Full workout retrieved successfully', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.expect(jsonData).to.have.property('sets');",
                  "    pm.expect(Array.isArray(jsonData.sets)).to.be.true;",
                  "    pm.expect(jsonData.sets.length).to.equal(3);",
                  "    // Verify nested structure",
                  "    jsonData.sets.forEach(function(set) {",
